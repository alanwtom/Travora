# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=your-supabase-project-url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# LLM Provider Configuration (for itinerary generation)
# Supported providers: openai, anthropic, gemini
EXPO_PUBLIC_LLM_PROVIDER=gemini
EXPO_PUBLIC_LLM_API_KEY=your-llm-api-key-here
EXPO_PUBLIC_LLM_MODEL=gemini-2.0-flash-exp

# Optional: External services for enhanced features
# EXPO_PUBLIC_WEATHER_API_KEY=
# EXPO_PUBLIC_MAPS_API_KEY=
